#!/usr/bin/env bash

#################
# Shell Options #
#################
if tty -s; then
  shopt -s checkwinsize
  shopt -s histappend
fi

####################
# Readline Options #
####################
if tty -s; then
  bind 'set colored-stats on'             # colorize completions using LS_COLORS
  bind 'set colored-completion-prefix on' # colorize the common prefix too
fi

#################
# File Sourcing #
#################
which brew >/dev/null || alias brew='true'
export BREW_PREFIX=$(brew --prefix)
SOURCE_FILES=(
  ## Main BASH Resources
  "${HOME}/.bash/paths"
  "${HOME}/.bash/variables"
  "${HOME}/.bash/functions"
  "${HOME}/.bash/aliases"
  "${HOME}/.bash/wsl"

  ## Other BASH Resources
  "${BREW_PREFIX}/etc/bash_completion"
  "${BREW_PREFIX}/etc/profile.d/bash_completion.sh"
)

for FILE in "${SOURCE_FILES[@]}"; do
  if [ -f "${FILE}" ]; then
    . "${FILE}"
  fi
done
