{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -eo pipefail

# ─── Sudo keepalive ──────────────────────────────────────────────────────────
# Cache sudo credentials upfront so we don't get prompted mid-script
sudo -n true 2>/dev/null || sudo -v
while true; do
    sudo -n true
    sleep 60
    kill -0 "$$" || exit
done 2>/dev/null &

# ─── Shell ───────────────────────────────────────────────────────────────────
BREW_PREFIX="$(brew --prefix)"
BREW_BASH="${BREW_PREFIX}/bin/bash"

# Set default shell to BASH
if [[ -f ${BREW_BASH} ]]; then
    grep -qF "${BREW_BASH}" /etc/shells ||
        echo "${BREW_BASH}" | sudo tee -a /etc/shells
    [[ ${BREW_BASH} == "$(dscl . -read "${HOME}" shell | awk '{print $2}')" ]] ||
        sudo chsh -s "${BREW_BASH}" "${USER}"
fi

# Enable 'NOPASSWD' for the 'admins' group
if [[ ! -f "/etc/sudoers.d/admins" ]]; then
    sudo mkdir -pv /etc/sudoers.d
    sudo touch /etc/sudoers.d/admins
    echo '%admin          ALL=(ALL)      NOPASSWD:ALL' >./admins
    sudo chown -v root:wheel ./admins
    sudo chmod -v 0440 ./admins
    sudo mv -v ./admins /etc/sudoers.d/admins
fi

# ─── Spotlight / locate db ───────────────────────────────────────────────────
sudo launchctl load -w /System/Library/LaunchDaemons/com.apple.locate.plist 2>/dev/null || true

# ─── Wallpaper ───────────────────────────────────────────────────────────────
{{- $wallpaper := joinPath .chezmoi.sourceDir "dot_config/macOS/Wallpaper_16_9.png" }}
osascript <<EOF
use framework "AppKit"
use scripting additions

tell application "System Events"
  set currentApp to name of first application process whose frontmost is true
end tell
tell application "Finder"
  activate
  delay 0.5
  set desktop picture to POSIX file "{{ $wallpaper }}"
end tell
tell application currentApp to activate
EOF

# ─── macOS system defaults ────────────────────────────────────────────────────
