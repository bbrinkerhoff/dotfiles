{{- if eq .chezmoi.os "windows" -}}
if (-Not (Get-Command winget -ErrorAction SilentlyContinue)) {
    Write-Host "Winget is not installed. Please install Winget to continue." -ForegroundColor Red
    exit 1
}

$packages = @(
{{ range .packages.windows.winget -}}
    "{{ . }}"
{{ end -}}
)

foreach ($package in $packages) {
    # Strip inline comments (anything after whitespace + #)
    $id = ($package -split '\s+#')[0].Trim()
    if (-not $id) { continue }

    Write-Host "Installing $id..." -ForegroundColor Cyan
    winget install --id $id -e --silent --accept-source-agreements --accept-package-agreements
    if ($LASTEXITCODE -ne 0 -and $LASTEXITCODE -ne -1978335189) {
        # -1978335189 (0x8A15002B) = already installed at latest version, not an error
        Write-Host "Warning: winget exited $LASTEXITCODE for $id" -ForegroundColor Yellow
    } else {
        Write-Host "OK: $id" -ForegroundColor Green
    }
}
{{- end -}}
