{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

set -eo pipefail

# ─── Sudo keepalive ──────────────────────────────────────────────────────────
# Cache sudo credentials upfront so we don't get prompted mid-script
sudo -n true 2>/dev/null || sudo -v
while true; do
    sudo -n true
    sleep 60
    kill -0 "$$" || exit
done 2>/dev/null &

# iTerm2 bashrc
if [[ ! -f "/etc/bashrc_iTerm.app" && -f "/etc/bashrc_Apple_Terminal" ]]; then
    sudo cp -v "/etc/bashrc_Apple_Terminal" "/etc/bashrc_iTerm.app"
fi

# ─── License keys ────────────────────────────────────────────────────────────
defaults write com.bjango.istatmenus.menubar.7 License -dict \
    License -string {{ onepasswordRead "op://Private/iStat Menus/license key" | quote }}

defaults write com.incrediblebee.Archiver LicenseKey \
    -string {{ onepasswordRead "op://Private/Archiver 5/license key" | quote }}

defaults write com.surteesstudios.Bartender license6 \
    -string {{ onepasswordRead "op://Private/Bartender 6/license key" | quote }}
defaults write com.surteesstudios.Bartender license6HoldersName \
    -string {{ onepasswordRead "op://Private/Bartender 6/license holder" | quote }}

defaults write com.rogueamoeba.soundsource registrationInfo -dict \
    Name -string {{ onepasswordRead "op://Private/Sound Source/Name" | quote }} \
    Code -string {{ onepasswordRead "op://Private/Sound Source/license key" | quote }}

# ─── App preferences ─────────────────────────────────────────────────────────
# iTerm2
defaults write com.googlecode.iterm2 LoadPrefsFromCustomFolder -bool true
defaults write com.googlecode.iterm2 PrefsCustomFolder -string "/Users/draco/.config/iterm2/iTermPreferences"

# Bartender
defaults write com.surteesstudios.Bartender launchAtLogin.isEnabled -int 1
defaults write com.surteesstudios.Bartender SUEnableAutomaticChecks -int 1
defaults write com.surteesstudios.Bartender TemporaryMenuBarItemShowTime -int 5
defaults write com.surteesstudios.Bartender DisableAllTriggers -int 0
defaults write com.surteesstudios.Bartender pausingEnabled -int 0
defaults write com.surteesstudios.Bartender supressDuringMoves -int 1

# SoundSource
defaults write com.rogueamoeba.soundsource menuBarIcon -string "speaker"
defaults write com.rogueamoeba.soundsource keyboardVolume -int 1
defaults write com.rogueamoeba.soundsource settingsPane -string "appearance"
defaults write com.rogueamoeba.soundsource applicationTheme -int 2

# iStat Menus 7
defaults write com.bjango.istatmenus.menubar.7 Battery '{Menubar={Mode={SingleValue={Percentage={Font={Name=default;Size=1;Weight=semibold;};Global={Value={Dark={Text={};};};};};};};};}'
defaults write com.bjango.istatmenus.menubar.7 Combined '{Menu={Items=(battery-battery,memory-overview,disks-physical,sensors-overview,disks-activity,network-bandwidth,processes);};}'
defaults write com.bjango.istatmenus.menubar.7 Menu '{Theme={Dark=system;};}'
defaults write com.bjango.istatmenus.menubar.7 Menubar '{CustomColor={Dark="0 0.8500000238418579 1 1";};Theme={Dark=custom;};}'
defaults write com.bjango.istatmenus.menubar.7 MenubarCurrentApperance 'Dark'
defaults write com.bjango.istatmenus.menubar.7 Notifications '{Items=({enabled=0;source=battery-low;type=alert;uuid=4e1abe18-f00e-4f2f-9a69-1ee6d04643f4;},{enabled=0;source=daylightsaving;time=0;type=alert;uuid=7ad71b8c-c416-49c9-a5bc-41f76628c118;},{enabled=0;item={key=any;};source=temperature;time=30;type=banner;uuid=3e5ac3eb-5a05-4b12-82fe-a51860e5851d;value=95;});}'
defaults write com.bjango.istatmenus.menubar.7 Profiles '{Available={identifier=default;};Settings={default={Battery={Menubar={DetailedState=0;Enabled=0;Items={NotCharging=();Standard=({source=8;subtype=11;type=4;});};};};CPU={Menubar={Enabled=0;};};Combined={Menubar={Enabled=1;Items=({source=21;});};};Disks={Menubar={Enabled=0;};};Memory={Menubar={Enabled=0;};};Network={Menubar={Enabled=0;};};Sensors={Menubar={Enabled=0;};};Time={Menubar={};};Weather={Menubar={};};};};}'

# BetterTouchTool
defaults write com.hegenberg.BetterTouchTool BTTSyncCloudProvider -int 2
defaults write com.hegenberg.BetterTouchTool SUAutomaticallyUpdate -int 1
defaults write com.hegenberg.BetterTouchTool launchOnStartup -int 1

# Github
git config --global credential.gitHubAccountFiltering "false"

# Nextcloud
defaults write com.nextcloud.desktopclient enabledAccounts -array \
    -string "bbrinkerhoff@bbhoff.ddns.net" \
    -string "DracoMedia@bbhoff.ddns.net"
defaults write com.nextcloud.desktopclient SUSendProfileInfo -bool false
defaults write com.nextcloud.desktopclient SUHasLaunchedBefore -bool true
defaults write com.nextcloud.desktopclient SUEnableAutomaticChecks -bool true
defaults write com.nextcloud.desktopclient SUAutomaticallyUpdate -bool true

# Openin
defaults write app.loshadki.OpenIn.v4 appSelectionReduceAnimation -bool true
defaults write app.loshadki.OpenIn.v4 appSelectionSize -int 32
defaults write app.loshadki.OpenIn.v4 hideTips -boot true
defaults write app.loshadki.OpenIn.v4 notificationsEnabled -boot true
defaults write app.loshadki.OpenIn.v4 startAtLogin -bool true
defaults write app.loshadki.OpenIn.v4 writeJavaScriptLogsToConsole -bool true

# Kill running processes
killall "Archiver" 2>/dev/null || true
killall "SoundSource" 2>/dev/null || true
killall "Bartender 6" 2>/dev/null || true
killall "BetterTouchTool" 2>/dev/null || true
killall "iStat Menus" 2>/dev/null || true
killall "Dock" 2>/dev/null || true
killall "Finder" 2>/dev/null || true
killall "iTerm" 2>/dev/null || true
killall "OpenIn" 2>/dev/null || true
killall "Nextcloud" 2>/dev/null || true

{{- end -}}
