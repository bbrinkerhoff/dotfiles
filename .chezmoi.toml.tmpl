# Enhanced Chezmoi Configuration

# This template file allows for cross-platform configuration, including Windows support.
# Centralized variables for all OSes with proper platform detection.

# Centralized Variables
[settings]
  home = "$HOME"
  config_dir = "${HOME}/.config"
  # Add any other centralized path variables here

# Platform Detection
{{ if eq .os "darwin" }}
  powershell_path = "C:\Program Files\PowerShell\7\pwsh.exe"
{{ else if eq .chezmoi.os "windows" }}
  [windows] # Windows-specific configurations
{{ else if eq .chezmoi.os "gnu-linux" }}
{{ else if eq .chezmoi.os "linux" }}

  [unix]
  # Unix/Linux specific configurations
  shell_path = "$(which bash)"
{{ end }}

# Add more cross-platform configuration settings as needed.
