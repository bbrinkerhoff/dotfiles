# Chezmoi configuration template

# Centralized variables
global_vars = {
  username = "{{ .Username }}"
  home_dir = "{{ .HomeDir }}"
}

# Cross-platform configurations
[[platforms]]
  name = "windows"
  # Windows specific settings
  data_dir = "C:\Users\{{ .username }}\.config"

[[platforms]]
  name = "linux"
  # Linux specific settings
  data_dir = "/home/{{ .username }}/.config"

[[platforms]]
  name = "darwin"
  # macOS specific settings
  data_dir = "/Users/{{ .username }}/.config"

# Additional configurations

[settings]
  log_level = "info"
  auto_update = true
